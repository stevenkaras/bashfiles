#!/usr/bin/env bash

# Determine the repository root directory relative to this script
ROOTDIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." && pwd )"

# Candidate patterns for nano syntax highlighters
candidate_patterns=(
	"/usr/share/nano*"
	"/usr/local/share/nano*"
	"/opt/homebrew/share/nano*"
)
if [[ -n "$PREFIX" ]]; then
	candidate_patterns+=("$PREFIX/share/nano*")
fi
candidate_patterns+=("/data/data/com.termux/files/usr/share/nano*")

includes=()
for pattern in "${candidate_patterns[@]}"; do
	dirs=($pattern)
	for dir in "${dirs[@]}"; do
		if [[ -d "$dir" ]]; then
			test_glob=("$dir"/*.nanorc)
			if [[ -e "${test_glob[0]}" ]]; then
				include_line="include $dir/*.nanorc"
				already_added=false
				for added in "${includes[@]}"; do
					if [[ "$added" == "$include_line" ]]; then
						already_added=true
						break
					fi
				done
				if [[ "$already_added" == "false" ]]; then
					includes+=("$include_line")
				fi
			fi
		fi
	done
done

echo "# Automatically generated by generate_nanorc"
for inc in "${includes[@]}"; do
	echo "$inc"
		done
echo ""

# Append personal configuration template if it exists
template_file="${1:-$ROOTDIR/templates/.config/nano/nanorc}"
if [[ -f "$template_file" ]]; then
	cat "$template_file"
fi
